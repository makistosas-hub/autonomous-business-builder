# =============================================================================
# RivalSense — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values before running locally.
# NEVER commit .env.local to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_NAME=RivalSense
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_CONVEX_URL=

# -----------------------------------------------------------------------------
# Convex Authentication
# Run `npx convex dev` to get your CONVEX_DEPLOYMENT value.
# Run `npx convex auth` or generate via dashboard for CONVEX_AUTH_SECRET.
# -----------------------------------------------------------------------------
CONVEX_DEPLOYMENT=
CONVEX_AUTH_SECRET=

# -----------------------------------------------------------------------------
# Google OAuth (for Google sign-in)
# Create credentials at https://console.cloud.google.com/apis/credentials
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Stripe
# Keys available at https://dashboard.stripe.com/apikeys
# Webhook secret generated via `stripe listen` locally or in Stripe dashboard
# Price IDs created after configuring products in Stripe dashboard
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_STARTER_PRICE_ID=
STRIPE_PRO_PRICE_ID=
STRIPE_ENTERPRISE_PRICE_ID=

# -----------------------------------------------------------------------------
# AI / OpenRouter
# API key available at https://openrouter.ai/keys
# -----------------------------------------------------------------------------
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-sonnet-4-6

# -----------------------------------------------------------------------------
# Monitoring — check intervals in hours
# These control how frequently each module polls competitor data.
# -----------------------------------------------------------------------------
PRICING_CHECK_INTERVAL=6
PRODUCT_CHECK_INTERVAL=12
WEBSITE_CHECK_INTERVAL=24
HIRING_CHECK_INTERVAL=12
POSITIONING_CHECK_INTERVAL=24

# Minimum significance score (1-10) required to create an alert
CHANGE_SIGNIFICANCE_THRESHOLD=5

# -----------------------------------------------------------------------------
# Tier Limits
# Values marked -1 are treated as unlimited.
# -----------------------------------------------------------------------------
FREE_TRIAL_DAYS=14

TIER_STARTER_COMPETITOR_LIMIT=3
TIER_STARTER_MEMBER_LIMIT=1
TIER_STARTER_MODULE_LIMIT=3
TIER_STARTER_HISTORY_DAYS=30

TIER_PRO_COMPETITOR_LIMIT=10
TIER_PRO_MEMBER_LIMIT=5
TIER_PRO_MODULE_LIMIT=5
TIER_PRO_HISTORY_DAYS=365

TIER_ENTERPRISE_COMPETITOR_LIMIT=-1
TIER_ENTERPRISE_MEMBER_LIMIT=-1
TIER_ENTERPRISE_MODULE_LIMIT=5
TIER_ENTERPRISE_HISTORY_DAYS=-1
